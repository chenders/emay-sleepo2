#!/usr/bin/env bash
# Pre-push hook: run all checks to catch CI failures locally.
# Failures here match what CI enforces.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
FAILED=()

section() { echo "===> $*"; }

# ---- Go ----
section "Go: fmt + vet + test"
(cd "$ROOT/go" && gofmt -l . | grep -q . && echo "FAIL: gofmt needed" && exit 1 || true
    go vet ./... && go test ./... -count=1) || FAILED+=("go")

# ---- Python ----
section "Python: format + lint + test"
(
    cd "$ROOT/python" && ruff format --check src/ tests/ && ruff check src/ tests/ &&
    if command -v uv &>/dev/null; then
        PYTHONPATH=src uv run --extra all python -m pytest tests/ -q
    else
        PYTHONPATH=src python -m pytest tests/ -q
    fi
) || FAILED+=("python")

# ---- Node ----
section "Node: fmt + tsc + test"
(cd "$ROOT/node" && npm ci --silent && npx prettier --check "src/**/*.ts" "tests/**/*.ts" &&
    npx tsc --noEmit && node --import tsx --test tests/*.test.ts) || FAILED+=("node")

# ---- Rust ----
section "Rust: fmt + clippy + test"
(
    CARGO="${CARGO:-$HOME/.cargo/bin/cargo}"
    [ -x "$CARGO" ] || CARGO="$(command -v cargo 2>/dev/null || true)"
    if [ -z "$CARGO" ]; then
        echo "SKIP: cargo not found (install rustup)"
    else
        cd "$ROOT/rust"
        "$CARGO" fmt --check && "$CARGO" clippy --features ble -- -D warnings &&
            "$CARGO" test --features ble -q
    fi
) || FAILED+=("rust")

# ---- Swift (macOS only) ----
section "Swift: build + test"
(
    if command -v swift &>/dev/null; then
        cd "$ROOT/swift"
        swift build --configuration release 2>&1 | tail -1
        # swiftpm-testing-helper crashes with SIGTRAP on exit (Xcode quirk).
        # Exit code is unreliable; check output text. pipefail off for this line.
        set +eo pipefail
        swift test 2>/dev/null | grep -q 'Test Suite.*passed' && passed=1 || passed=0
        set -eo pipefail
        if [ "$passed" = "1" ]; then
            echo "    ✓ All Swift tests passed"
        else
            echo "    ✘ Swift tests FAILED"
            exit 1
        fi
    else
        echo "SKIP: swift not found (macOS with Xcode required)"
    fi
) || FAILED+=("swift")

# ---- Summary ----
if [ ${#FAILED[@]} -eq 0 ]; then
    echo ""
    echo "All pre-push checks passed."
    exit 0
else
    echo ""
    echo "FAILED: ${FAILED[*]}"
    exit 1
fi
